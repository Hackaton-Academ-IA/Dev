generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  user
  admin
}

model Utilisateur {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified Boolean?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  niveau        Int       @default(1)
  xp            Int       @default(0)
  hp            Int       @default(5)
  pieces        Int       @default(0)
  lastDailyAt       DateTime?
  dailyQuestsDone   Int       @default(0)
  streak            Int       @default(0)
  lastPlayedAt      DateTime?
  role              Role      @default(user)
  sessions      Session[]
  accounts      Account[]
  reponses      Reponse[]
  badges             UtilisateurBadge[]
  historique         HistoriqueQuiz[]
  donjonProgressions DonjonProgression[]

  @@map("user")
}

model DonjonProgression {
  id       String      @id @default(uuid())
  userId   String
  donjonId Int
  status   String      @default("LOCKED")
  user     Utilisateur @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, donjonId])
  @@map("donjon_progression")
}

model Session {
  id        String      @id @default(uuid())
  expiresAt DateTime
  token     String      @unique
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      Utilisateur @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String      @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  user                  Utilisateur @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model Question {
  id               String    @id @default(uuid())
  contenu          String
  difficulte       String
  matiere          String    // <-- NOUVEAU
  choix            String[]  // <-- NOUVEAU (Tableau de chaînes de caractères)
  explication      String    // <-- NOUVEAU
  correctIndex     Int?      // <-- NOUVEAU (Optionnel, utile pour plus tard)
  reponse_attendue String
  
  reponses         Reponse[]
}

model Reponse {
  id            String      @id @default(uuid())
  est_correct   Boolean
  temps_reponse Int
  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id])
  questionId    String
  question      Question    @relation(fields: [questionId], references: [id])
}

model Badge {
  id           String             @id @default(uuid())
  nom          String
  icone        String
  xp_requis    Int
  utilisateurs UtilisateurBadge[]
}

model UtilisateurBadge {
  id            String      @id @default(uuid())
  dateObtention DateTime    @default(now())
  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id])
  badgeId       String
  badge         Badge       @relation(fields: [badgeId], references: [id])
}

model HistoriqueQuiz {
  id            String      @id @default(uuid())
  score         Int
  nbQuestions   Int
  difficulte    String
  datePassage   DateTime    @default(now())
  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
}