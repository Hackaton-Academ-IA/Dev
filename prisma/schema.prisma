generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

// ------------------------------------------------------
// 1. Le Modèle Principal (Fusion Better-Auth + RPG)
// ------------------------------------------------------
model Utilisateur {
  id            String    @id @default(uuid())
  
  // Champs standards Better-Auth
  name          String?   // Mappé sur ton 'pseudo' dans auth.ts
  email         String    @unique
  emailVerified Boolean?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Tes champs RPG personnalisés
  niveau        Int       @default(1)
  xp            Int       @default(0)
  role          Role      @default(USER)

  // Relations
  sessions      Session[]
  accounts      Account[]
  reponses      Reponse[]
  badges        UtilisateurBadge[]
  historique    HistoriqueQuiz[]

  @@map("user") // CRUCIAL : Dit à Postgres de nommer cette table "user" en base
}

// ------------------------------------------------------
// 2. Les Tables Obligatoires de Better-Auth
// ------------------------------------------------------
model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      Utilisateur @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  user                  Utilisateur @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// ------------------------------------------------------
// 3. Tes Modèles Métier (Inchangés)
// ------------------------------------------------------
model Question {
  id               String    @id @default(uuid())
  contenu          String
  difficulte       String    
  reponse_attendue String
  reponses         Reponse[]
}

model Reponse {
  id             String      @id @default(uuid())
  est_correct    Boolean
  temps_reponse  Int         
  
  utilisateurId  String
  utilisateur    Utilisateur @relation(fields: [utilisateurId], references: [id])
  
  questionId     String
  question       Question    @relation(fields: [questionId], references: [id])
}

model Badge {
  id           String             @id @default(uuid())
  nom          String
  icone        String
  xp_requis    Int
  utilisateurs UtilisateurBadge[]
}

model UtilisateurBadge {
  id            String      @id @default(uuid())
  dateObtention DateTime    @default(now())

  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id])

  badgeId       String
  badge         Badge       @relation(fields: [badgeId], references: [id])
}

model HistoriqueQuiz {
  id            String      @id @default(uuid())
  score         Int
  nbQuestions   Int
  difficulte    String
  datePassage   DateTime    @default(now())

  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
}